# Normalize line endings to LF in the repository, checkout as native on Windows
* text=auto

# Explicitly LF for source files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Windows scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
*.whl binary
